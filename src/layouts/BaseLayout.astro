---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const siteUrl = 'https://tradecalchub.com';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : Astro.url.href;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.png`;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="google-site-verification" content="Icne4_0Suh2f_42VP4v9H8giy6kShPYRb11MbsHD08Y" />
  <!-- Ezoic — uncomment after approval and replace with your Ezoic script tag
  <script src="https://the.gatekeeperconsent.com/cmp.min.js" data-cfasync="false"></script>
  <script>var ezstandalone = ezstandalone || {}; ezstandalone.cmd = ezstandalone.cmd || [];</script>
  -->
  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="2" width="24" height="24" rx="4" fill="#1a56db"/>
          <path d="M8 9h12M8 14h12M8 19h8" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        </svg>
        TradeCalc Hub
      </a>
      <nav class="header-nav">
        <a href="/">Calculators</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-links">
      <a href="/">All Calculators</a>
      <a href="/calculators">Calculator Index</a>
      <a href="/about">About</a>
      <a href="/faq">FAQ</a>
      <a href="/contact">Contact</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="https://ko-fi.com/tradecalchub" target="_blank" rel="noopener">Support Us</a>
    </div>
    <p>&copy; {new Date().getFullYear()} TradeCalc Hub. Free construction calculators for professionals and DIYers.</p>
  </footer>

  <!-- Skimlinks — pending approval, will activate automatically once approved -->
  <script type="text/javascript" src="https://s.skimresources.com/js/300110X1787940.skimlinks.js"></script>

  <!-- Cloudflare Web Analytics — replace token after setup -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "YOUR_CF_ANALYTICS_TOKEN"}'></script>
</body>
</html>
