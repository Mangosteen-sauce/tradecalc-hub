---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculators } from '../data/calculators';
---

<BaseLayout
  title="Page Not Found — TradeCalc Hub"
  description="The page you're looking for doesn't exist. Browse our free construction calculators."
>
  <div style="text-align:center;padding:3rem 1rem;">
    <h1 style="font-size:3rem;color:var(--color-text-light);margin-bottom:0.5rem;">404</h1>
    <p style="font-size:1.25rem;margin-bottom:0.5rem;">Page not found</p>
    <p style="color:var(--color-text-light);margin-bottom:2rem;">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" style="display:inline-block;padding:0.75rem 1.5rem;background:var(--color-primary);color:#fff;border-radius:var(--radius);font-weight:600;text-decoration:none;">Browse All Calculators</a>
  </div>

  <div style="max-width:900px;margin:0 auto;">
    <h2 style="font-size:1.1rem;margin-bottom:1rem;text-align:center;color:var(--color-text-light);">Popular Calculators</h2>
    <div class="calc-grid">
      {calculators.slice(0, 6).map((calc) => (
        <a href={`/calculators/${calc.slug}`} class="calc-grid-item">
          <div class="icon">{calc.icon}</div>
          <h3 style="font-size:1rem;margin-bottom:0.25rem;color:var(--color-text);">{calc.name}</h3>
          <p>{calc.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
