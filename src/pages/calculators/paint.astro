---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculators } from '../../data/calculators';
import FeedbackWidget from '../../components/FeedbackWidget.astro';
import KofiButton from '../../components/KofiButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getAffiliateLinksForCalculator } from '../../data/affiliates';
const calc = calculators.find(c => c.slug === 'paint')!;
const relatedCalcs = calc.related.map(r => calculators.find(c => c.slug === r)!);
const affiliateLinks = getAffiliateLinksForCalculator('paint');
const title = 'Paint Calculator | Gallons Needed for Walls & Ceilings';
const description = 'Free paint calculator. Estimate gallons of paint needed for walls and ceilings. Account for doors, windows, and number of coats.';
---

<BaseLayout title={title} description={description} canonical="/calculators/paint">
  <nav class="breadcrumbs">
    <a href="/">Home</a><span>/</span><a href="/calculators">Calculators</a><span>/</span>Paint
  </nav>

  <div class="calc-card">
    <h1>Paint Calculator</h1>
    <p class="subtitle">Calculate gallons of paint for walls and ceilings by room dimensions.</p>

    <div class="unit-toggle" id="unitToggle">
      <button class="active" data-unit="imperial">Imperial (ft)</button>
      <button data-unit="metric">Metric (m)</button>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Room Length <span class="hint unit-label">(feet)</span></label>
        <input type="number" id="roomLength" placeholder="0" min="0" step="any" />
      </div>
      <div class="form-group">
        <label>Room Width <span class="hint unit-label">(feet)</span></label>
        <input type="number" id="roomWidth" placeholder="0" min="0" step="any" />
      </div>
    </div>

    <div class="form-group">
      <label>Wall Height <span class="hint unit-label">(feet)</span></label>
      <input type="number" id="wallHeight" placeholder="0" min="0" step="any" />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Number of Coats</label>
        <select id="coats">
          <option value="1">1 coat</option>
          <option value="2" selected>2 coats (recommended)</option>
          <option value="3">3 coats</option>
        </select>
      </div>
      <div class="form-group">
        <label>Include Ceiling?</label>
        <select id="ceiling">
          <option value="no">No - walls only</option>
          <option value="yes">Yes - walls + ceiling</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Cost per Gallon <span class="hint">(optional, $)</span></label>
      <input type="number" id="costPerGallon" placeholder="0" min="0" step="any" />
    </div>

    <!-- Advanced Options -->
    <details class="advanced-options" id="advancedOptions">
      <summary>Advanced Options</summary>
      <div class="advanced-inner">

        <div class="form-group">
          <label>Surface Type</label>
          <select id="surfaceType">
            <option value="350">Standard / Eggshell (350 sq ft/gal)</option>
            <option value="400">Smooth / Flat (400 sq ft/gal)</option>
            <option value="250">Textured / Stucco (250 sq ft/gal)</option>
          </select>
        </div>

        <div class="form-group">
          <label>Add Primer Coat?</label>
          <select id="primer">
            <option value="no">No primer</option>
            <option value="yes">Yes - add primer (250 sq ft/gal)</option>
          </select>
        </div>

        <span class="advanced-section-label">Doors to Subtract</span>
        <div class="opening-rows" id="doorRows">
          <div class="opening-row" data-row="door">
            <select class="door-type">
              <option value="21">Interior (21 sq ft)</option>
              <option value="23">Exterior (23 sq ft)</option>
              <option value="40">Sliding Glass (40 sq ft)</option>
              <option value="custom">Custom (H × W)</option>
            </select>
            <div class="custom-dims" style="display:none;">
              <input type="number" class="door-h" placeholder="H" min="0" step="any" />
              <input type="number" class="door-w" placeholder="W" min="0" step="any" />
            </div>
            <input type="number" class="qty-input" value="2" min="0" step="1" title="Count" />
            <button type="button" class="btn-remove-row" title="Remove">×</button>
          </div>
        </div>
        <button type="button" class="btn-add-row" id="addDoorRow">+ Add door type</button>

        <span class="advanced-section-label" style="margin-top:0.75rem;">Windows to Subtract</span>
        <div class="opening-rows" id="windowRows">
          <div class="opening-row" data-row="window">
            <select class="window-type">
              <option value="12">Standard (12 sq ft)</option>
              <option value="6">Small (6 sq ft)</option>
              <option value="20">Picture (20 sq ft)</option>
              <option value="30">Bay (30 sq ft)</option>
              <option value="custom">Custom (H × W)</option>
            </select>
            <div class="custom-dims" style="display:none;">
              <input type="number" class="win-h" placeholder="H" min="0" step="any" />
              <input type="number" class="win-w" placeholder="W" min="0" step="any" />
            </div>
            <input type="number" class="qty-input" value="2" min="0" step="1" title="Count" />
            <button type="button" class="btn-remove-row" title="Remove">×</button>
          </div>
        </div>
        <button type="button" class="btn-add-row" id="addWindowRow">+ Add window type</button>

        <span class="advanced-section-label" style="margin-top:0.75rem;">Other Exclusions</span>
        <div class="opening-rows" id="exclusionRows"></div>
        <button type="button" class="btn-add-row" id="addExclusionRow">+ Add exclusion (columns, murals, etc.)</button>

      </div>
    </details>

    <button class="btn-calculate" id="calcBtn">Calculate Paint</button>

    <div class="results-panel" id="results">
      <h2>Results</h2>
      <div class="result-row">
        <span class="result-label">Paintable Area</span>
        <span class="result-value" id="resArea">—</span>
      </div>
      <div class="result-row">
        <span class="result-label">Gallons Needed</span>
        <span class="result-value" id="resGallons">—</span>
      </div>
      <div class="result-row" id="primerRow" style="display:none;">
        <span class="result-label">Primer Gallons</span>
        <span class="result-value" id="resPrimer">—</span>
      </div>
      <div class="result-row" id="costRow" style="display:none;">
        <span class="result-label">Estimated Cost</span>
        <span class="result-value" id="resCost">—</span>
      </div>
      <p class="result-note" id="resultNote">Based on 350 sq ft coverage per gallon. Textured walls or porous surfaces may require more paint.</p>
      <ShareButtons />
    </div>
  </div>

  <div class="ad-slot">Advertisement</div>

  <div class="content-section">
    <h2>How to Calculate Paint</h2>
    <p>One gallon of paint covers approximately 350-400 square feet of smooth wall surface. To calculate how many gallons you need, find the total wall area and subtract openings.</p>

    <h3>Paint Formula</h3>
    <div class="formula-box">
      Wall Area = Perimeter × Height<br>
      Subtract: Doors + Windows + Other Exclusions<br>
      Gallons = (Paintable Area × Coats) / Coverage Rate
    </div>

    <h3>Coverage Rates</h3>
    <ul>
      <li><strong>Flat/matte paint:</strong> 350-400 sq ft per gallon</li>
      <li><strong>Eggshell/satin:</strong> 350 sq ft per gallon</li>
      <li><strong>Semi-gloss:</strong> 350 sq ft per gallon</li>
      <li><strong>Primer:</strong> 200-300 sq ft per gallon (more porous)</li>
    </ul>

    <h3>When to Use Extra Coats</h3>
    <ul>
      <li><strong>1 coat:</strong> Touching up the same color, or using paint + primer over existing light color</li>
      <li><strong>2 coats:</strong> Standard for most repaints and color changes</li>
      <li><strong>3 coats:</strong> Going from dark to light, painting over stains, deep reds or yellows</li>
    </ul>

    <h3>Tips for Buying Paint</h3>
    <ul>
      <li>Always round up to the nearest gallon. Leftover paint is good for touch-ups</li>
      <li>Buy all paint at once to ensure consistent color (same batch/lot)</li>
      <li>Textured walls use 20-30% more paint than smooth walls</li>
      <li>Standard door size is 3' × 7' (21 sq ft); standard window is 3' × 4' (12 sq ft)</li>
      <li>For large rooms, a <a href={affiliateLinks[0]?.url} target="_blank">{affiliateLinks[0]?.text}</a> can cut application time in half compared to brushing</li>
      <li>A quality <a href={affiliateLinks[1]?.url} target="_blank">{affiliateLinks[1]?.text}</a> gives a smooth, even finish on walls and ceilings</li>
    </ul>
  </div>

  <div class="related-calcs" style="margin-top:2rem;">
    <h2 style="font-size:1.25rem;margin-bottom:1rem;">Related Calculators</h2>
    <div class="calc-grid" style="max-width:100%;">
      {relatedCalcs.map(rc => (
        <a href={`/calculators/${rc.slug}`} class="calc-grid-item">
          <div class="icon"><img src={rc.icon} alt={rc.name} width="48" height="48" /></div>
          <h3 style="font-size:1rem;margin-bottom:0.25rem;color:var(--color-text);">{rc.name}</h3>
          <p>{rc.description}</p>
        </a>
      ))}
    </div>
  </div>

  <KofiButton />
  <FeedbackWidget calculatorName={calc.name} />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Paint Calculator",
      "url": "https://tradecalchub.com/calculators/paint",
      "description": description,
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradecalchub.com" },
        { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://tradecalchub.com/calculators" },
        { "@type": "ListItem", "position": 3, "name": calc.shortName }
      ]
    })} />
  </Fragment>
</BaseLayout>

<script>
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const $$ = (s: string) => document.querySelectorAll(s);
  const val = (s: string) => parseFloat(($(s) as HTMLInputElement).value) || 0;

  let unit: 'imperial' | 'metric' = 'imperial';

  $$('#unitToggle button').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('#unitToggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      unit = (btn as HTMLElement).dataset.unit as 'imperial' | 'metric';
      $$('.unit-label').forEach(el => el.textContent = `(${unit === 'imperial' ? 'feet' : 'meters'})`);
    });
  });

  // --- Dynamic row helpers ---
  function setupCustomToggle(row: Element, typeClass: string, dimsSelector: string) {
    const select = row.querySelector(typeClass) as HTMLSelectElement;
    const dims = row.querySelector(dimsSelector) as HTMLElement;
    if (!select || !dims) return;
    select.addEventListener('change', () => {
      dims.style.display = select.value === 'custom' ? '' : 'none';
    });
  }

  function addDoorRow() {
    const container = $('#doorRows');
    const row = document.createElement('div');
    row.className = 'opening-row';
    row.dataset.row = 'door';
    row.innerHTML = `
      <select class="door-type">
        <option value="21">Interior (21 sq ft)</option>
        <option value="23">Exterior (23 sq ft)</option>
        <option value="40">Sliding Glass (40 sq ft)</option>
        <option value="custom">Custom (H × W)</option>
      </select>
      <div class="custom-dims" style="display:none;">
        <input type="number" class="door-h" placeholder="H" min="0" step="any" />
        <input type="number" class="door-w" placeholder="W" min="0" step="any" />
      </div>
      <input type="number" class="qty-input" value="1" min="0" step="1" title="Count" />
      <button type="button" class="btn-remove-row" title="Remove">×</button>`;
    container.appendChild(row);
    setupCustomToggle(row, '.door-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  }

  function addWindowRow() {
    const container = $('#windowRows');
    const row = document.createElement('div');
    row.className = 'opening-row';
    row.dataset.row = 'window';
    row.innerHTML = `
      <select class="window-type">
        <option value="12">Standard (12 sq ft)</option>
        <option value="6">Small (6 sq ft)</option>
        <option value="20">Picture (20 sq ft)</option>
        <option value="30">Bay (30 sq ft)</option>
        <option value="custom">Custom (H × W)</option>
      </select>
      <div class="custom-dims" style="display:none;">
        <input type="number" class="win-h" placeholder="H" min="0" step="any" />
        <input type="number" class="win-w" placeholder="W" min="0" step="any" />
      </div>
      <input type="number" class="qty-input" value="1" min="0" step="1" title="Count" />
      <button type="button" class="btn-remove-row" title="Remove">×</button>`;
    container.appendChild(row);
    setupCustomToggle(row, '.window-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  }

  function addExclusionRow() {
    const container = $('#exclusionRows');
    const row = document.createElement('div');
    row.className = 'opening-row';
    row.dataset.row = 'exclusion';
    row.innerHTML = `
      <input type="text" class="excl-name" placeholder="Name (e.g. column)" style="font-size:0.85rem;padding:0.45rem 0.6rem;" />
      <div class="custom-dims">
        <input type="number" class="excl-h" placeholder="H (ft)" min="0" step="any" />
        <input type="number" class="excl-w" placeholder="W (ft)" min="0" step="any" />
      </div>
      <input type="number" class="qty-input" value="1" min="0" step="1" title="Count" />
      <button type="button" class="btn-remove-row" title="Remove">×</button>`;
    container.appendChild(row);
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  }

  // Wire up initial rows and add buttons
  document.querySelectorAll('#doorRows .opening-row').forEach(row => {
    setupCustomToggle(row, '.door-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  });
  document.querySelectorAll('#windowRows .opening-row').forEach(row => {
    setupCustomToggle(row, '.window-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  });

  $('#addDoorRow').addEventListener('click', addDoorRow);
  $('#addWindowRow').addEventListener('click', addWindowRow);
  $('#addExclusionRow').addEventListener('click', addExclusionRow);

  // --- Calculation helpers ---
  function getDoorArea(): number {
    let total = 0;
    document.querySelectorAll('#doorRows .opening-row').forEach(row => {
      const select = row.querySelector('.door-type') as HTMLSelectElement;
      const qty = parseFloat((row.querySelector('.qty-input') as HTMLInputElement).value) || 0;
      if (select.value === 'custom') {
        let h = parseFloat((row.querySelector('.door-h') as HTMLInputElement).value) || 0;
        let w = parseFloat((row.querySelector('.door-w') as HTMLInputElement).value) || 0;
        if (unit === 'metric') { h *= 3.28084; w *= 3.28084; }
        total += h * w * qty;
      } else {
        total += parseFloat(select.value) * qty;
      }
    });
    return total;
  }

  function getWindowArea(): number {
    let total = 0;
    document.querySelectorAll('#windowRows .opening-row').forEach(row => {
      const select = row.querySelector('.window-type') as HTMLSelectElement;
      const qty = parseFloat((row.querySelector('.qty-input') as HTMLInputElement).value) || 0;
      if (select.value === 'custom') {
        let h = parseFloat((row.querySelector('.win-h') as HTMLInputElement).value) || 0;
        let w = parseFloat((row.querySelector('.win-w') as HTMLInputElement).value) || 0;
        if (unit === 'metric') { h *= 3.28084; w *= 3.28084; }
        total += h * w * qty;
      } else {
        total += parseFloat(select.value) * qty;
      }
    });
    return total;
  }

  function getExclusionArea(): number {
    let total = 0;
    document.querySelectorAll('#exclusionRows .opening-row').forEach(row => {
      let h = parseFloat((row.querySelector('.excl-h') as HTMLInputElement).value) || 0;
      let w = parseFloat((row.querySelector('.excl-w') as HTMLInputElement).value) || 0;
      const qty = parseFloat((row.querySelector('.qty-input') as HTMLInputElement).value) || 0;
      if (unit === 'metric') { h *= 3.28084; w *= 3.28084; }
      total += h * w * qty;
    });
    return total;
  }

  // --- Main calculation ---
  $('#calcBtn').addEventListener('click', () => {
    let l = val('#roomLength'), w = val('#roomWidth'), h = val('#wallHeight');
    if (unit === 'metric') { l *= 3.28084; w *= 3.28084; h *= 3.28084; }

    const perimeter = 2 * (l + w);
    const wallArea = perimeter * h;
    const coats = parseInt((document.querySelector('#coats') as HTMLSelectElement).value);
    const includeCeiling = (document.querySelector('#ceiling') as HTMLSelectElement).value === 'yes';

    // Use advanced options if the panel is open, otherwise use defaults
    const advOpen = ($('#advancedOptions') as HTMLDetailsElement).open;
    let doorArea: number, windowArea: number, exclusionArea: number;
    let coverageRate: number;
    let addPrimer: boolean;

    if (advOpen) {
      doorArea = getDoorArea();
      windowArea = getWindowArea();
      exclusionArea = getExclusionArea();
      coverageRate = parseInt((document.querySelector('#surfaceType') as HTMLSelectElement).value);
      addPrimer = (document.querySelector('#primer') as HTMLSelectElement).value === 'yes';
    } else {
      // Default behavior: 2 doors × 21 + 2 windows × 15 (matching defaults in the rows)
      doorArea = getDoorArea();
      windowArea = getWindowArea();
      exclusionArea = 0;
      coverageRate = 350;
      addPrimer = false;
    }

    let paintableArea = wallArea - doorArea - windowArea - exclusionArea;
    if (includeCeiling) paintableArea += l * w;
    if (paintableArea <= 0) return;

    const gallons = Math.ceil((paintableArea * coats) / coverageRate);

    const areaLabel = unit === 'metric'
      ? `${(paintableArea * 0.092903).toFixed(0)} m²`
      : `${paintableArea.toFixed(0)} sq ft`;

    $('#resArea').textContent = areaLabel;
    $('#resGallons').textContent = `${gallons} gallon${gallons > 1 ? 's' : ''}`;
    $('#resultNote').textContent = `Based on ${coverageRate} sq ft coverage per gallon.`;

    if (addPrimer) {
      const primerGallons = Math.ceil(paintableArea / 250);
      $('#resPrimer').textContent = `${primerGallons} gallon${primerGallons > 1 ? 's' : ''}`;
      $('#primerRow').style.display = '';
    } else {
      $('#primerRow').style.display = 'none';
    }

    const cost = val('#costPerGallon');
    if (cost > 0) {
      let totalGallons = gallons;
      if (addPrimer) totalGallons += Math.ceil(paintableArea / 250);
      $('#resCost').textContent = `$${(totalGallons * cost).toFixed(2)}`;
      $('#costRow').style.display = '';
    } else {
      $('#costRow').style.display = 'none';
    }

    $('#results').classList.add('visible');
  });

</script>
