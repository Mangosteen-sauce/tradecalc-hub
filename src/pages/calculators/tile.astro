---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculators } from '../../data/calculators';
import FeedbackWidget from '../../components/FeedbackWidget.astro';
import KofiButton from '../../components/KofiButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getAffiliateLinksForCalculator } from '../../data/affiliates';
const calc = calculators.find(c => c.slug === 'tile')!;
const relatedCalcs = calc.related.map(r => calculators.find(c => c.slug === r)!);
const affiliateLinks = getAffiliateLinksForCalculator('tile');
const title = 'Tile & Flooring Calculator | Square Footage & Tiles Needed';
const description = 'Free tile and flooring calculator. Estimate tiles, boxes, and cost with customizable waste factor. Works for ceramic, porcelain, vinyl, and hardwood.';
---

<BaseLayout title={title} description={description} canonical="/calculators/tile">
  <nav class="breadcrumbs">
    <a href="/">Home</a><span>/</span><a href="/calculators">Calculators</a><span>/</span>Tile
  </nav>

  <div class="calc-card">
    <h1>Tile & Flooring Calculator</h1>
    <p class="subtitle">Calculate tiles, boxes, and cost for floors and walls with waste factor.</p>

    <div class="unit-toggle" id="unitToggle">
      <button class="active" data-unit="imperial">Imperial (ft)</button>
      <button data-unit="metric">Metric (m)</button>
    </div>

    <!-- Shape Selector -->
    <div>
      <label style="font-weight:600;font-size:0.875rem;margin-bottom:0.5rem;display:block;">Room Shape</label>
      <div class="shape-selector">
        <button class="shape-btn active" data-shape="rectangle">Rectangle</button>
        <button class="shape-btn" data-shape="l-shape">L-Shape</button>
        <button class="shape-btn" data-shape="u-shape">U-Shape</button>
        <button class="shape-btn" data-shape="triangle">Triangle</button>
      </div>
    </div>

    <!-- Rectangle Inputs (default) -->
    <div id="rectInputs">
      <div class="form-row">
        <div class="form-group">
          <label>Area Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="areaLength" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Area Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="areaWidth" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- L-Shape Inputs -->
    <div id="lInputs" style="display:none;">
      <p class="hint" style="margin-bottom:0.5rem;">Enter two rectangles that form the L-shape.</p>
      <div class="form-row">
        <div class="form-group">
          <label>Section 1 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l1Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 1 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l1Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Section 2 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l2Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 2 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l2Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- U-Shape Inputs -->
    <div id="uInputs" style="display:none;">
      <p class="hint" style="margin-bottom:0.5rem;">Enter three rectangles that form the U-shape.</p>
      <div class="form-row">
        <div class="form-group">
          <label>Section 1 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u1Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 1 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u1Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Section 2 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u2Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 2 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u2Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Section 3 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u3Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 3 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="u3Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- Triangle Inputs -->
    <div id="triInputs" style="display:none;">
      <div class="form-row">
        <div class="form-group">
          <label>Base <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="triBase" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Height <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="triHeight" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Tile Length <span class="hint" id="tileLenHint">(inches)</span></label>
        <input type="number" id="tileLength" placeholder="0" min="0" step="any" />
      </div>
      <div class="form-group">
        <label>Tile Width <span class="hint" id="tileWidHint">(inches)</span></label>
        <input type="number" id="tileWidth" placeholder="0" min="0" step="any" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Waste Factor</label>
        <select id="waste">
          <option value="5">5% - simple rectangular room</option>
          <option value="10" selected>10% - standard (recommended)</option>
          <option value="15">15% - diagonal layout or complex shape</option>
          <option value="20">20% - complex pattern (herringbone, etc.)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Tiles per Box <span class="hint">(optional)</span></label>
        <input type="number" id="tilesPerBox" placeholder="0" min="1" step="1" />
      </div>
    </div>

    <div class="form-group">
      <label>Cost per Sq Ft <span class="hint">(optional, $)</span></label>
      <input type="number" id="costPerSqFt" placeholder="0" min="0" step="any" />
    </div>

    <!-- Advanced Options -->
    <details class="advanced-options">
      <summary>Advanced Options</summary>
      <div class="advanced-inner">

        <div class="form-group">
          <label>Subtract Obstacles <span class="hint">(total sq ft for toilets, vanities, islands)</span></label>
          <input type="number" id="obstacles" placeholder="0" min="0" step="any" value="0" />
        </div>

        <div class="form-group">
          <label>Grout Line Width</label>
          <select id="groutWidth">
            <option value="0">No grout calculation</option>
            <option value="0.0625">1/16" (thin)</option>
            <option value="0.125">1/8" (standard)</option>
            <option value="0.1875">3/16"</option>
            <option value="0.25">1/4" (wide)</option>
          </select>
        </div>

        <div class="form-group">
          <label>Estimate Thinset?</label>
          <select id="thinset">
            <option value="no">No</option>
            <option value="yes">Yes (50 lb bag per 65 sq ft)</option>
          </select>
        </div>

      </div>
    </details>

    <button class="btn-calculate" id="calcBtn">Calculate Tiles</button>

    <div class="results-panel" id="results">
      <h2>Results</h2>
      <div class="result-row">
        <span class="result-label">Room Area</span>
        <span class="result-value" id="resArea">—</span>
      </div>
      <div class="result-row">
        <span class="result-label">Area with Waste</span>
        <span class="result-value" id="resAreaWaste">—</span>
      </div>
      <div class="result-row">
        <span class="result-label">Tiles Needed</span>
        <span class="result-value" id="resTiles">—</span>
      </div>
      <div class="result-row" id="boxRow" style="display:none;">
        <span class="result-label">Boxes Needed</span>
        <span class="result-value" id="resBoxes">—</span>
      </div>
      <div class="result-row" id="groutRow" style="display:none;">
        <span class="result-label">Grout Needed</span>
        <span class="result-value" id="resGrout">—</span>
      </div>
      <div class="result-row" id="thinsetRow" style="display:none;">
        <span class="result-label">Thinset Bags (50 lb)</span>
        <span class="result-value" id="resThinset">—</span>
      </div>
      <div class="result-row" id="costRow" style="display:none;">
        <span class="result-label">Estimated Cost</span>
        <span class="result-value" id="resCost">—</span>
      </div>
      <p class="result-note">Always buy a few extra tiles for future repairs. Tile dye lots may vary between orders.</p>
      <ShareButtons />
    </div>
  </div>

  <div class="ad-slot">Advertisement</div>

  <div class="content-section">
    <h2>How to Calculate Tile</h2>
    <p>To calculate how many tiles you need, divide the total area by the area of a single tile, then add waste for cuts and breakage.</p>

    <h3>Tile Formula</h3>
    <div class="formula-box">
      Room Area = Length × Width (in sq ft)<br>
      Tile Area = (Tile Length × Tile Width) / 144 (in sq ft)<br>
      Tiles Needed = (Room Area × (1 + Waste%)) / Tile Area<br>
      Grout (lbs) = Tiles × Tile Perimeter × Grout Width × 0.375 / 13.5<br>
      Thinset (bags) = Area / 65
    </div>

    <h3>Common Tile Sizes</h3>
    <ul>
      <li><strong>12" × 12":</strong> Classic floor tile, 1 sq ft each</li>
      <li><strong>12" × 24":</strong> Modern rectangular format, popular for floors</li>
      <li><strong>18" × 18":</strong> Large format, makes rooms look bigger</li>
      <li><strong>24" × 24":</strong> Extra-large, minimal grout lines</li>
      <li><strong>3" × 6":</strong> Subway tile (walls and backsplashes)</li>
      <li><strong>6" × 6":</strong> Traditional wall tile</li>
    </ul>

    <h3>Waste Factor Guide</h3>
    <ul>
      <li><strong>5%:</strong> Simple rectangular room, straight lay, experienced installer</li>
      <li><strong>10%:</strong> Standard recommendation for most projects</li>
      <li><strong>15%:</strong> Diagonal layouts, L-shaped rooms, lots of cuts</li>
      <li><strong>20%:</strong> Herringbone, chevron, or complex patterns</li>
    </ul>

    <h3>Don't Forget</h3>
    <ul>
      <li><strong>Grout:</strong> 1 lb per 5-10 sq ft depending on tile size and gap width</li>
      <li><strong>Thinset mortar:</strong> 1 bag (50 lbs) covers ~60-75 sq ft with a 1/4"x3/8" trowel. Large-format tiles (18"+) need a bigger trowel and use 30-50% more thinset</li>
      <li><strong>Backer board:</strong> Required for wet areas (shower, tub surround)</li>
      <li><strong>Spacers:</strong> 1 bag per 100 sq ft (1/8" or 1/16" size)</li>
    </ul>
    <p>A quality <a href={affiliateLinks[0]?.url} target="_blank">{affiliateLinks[0]?.text}</a> makes cuts faster and cleaner, especially for large-format tiles. You'll also want a set of <a href={affiliateLinks[1]?.url} target="_blank">{affiliateLinks[1]?.text}</a> for consistent grout lines.</p>
  </div>

  <div class="related-calcs" style="margin-top:2rem;">
    <h2 style="font-size:1.25rem;margin-bottom:1rem;">Related Calculators</h2>
    <div class="calc-grid" style="max-width:100%;">
      {relatedCalcs.map(rc => (
        <a href={`/calculators/${rc.slug}`} class="calc-grid-item">
          <div class="icon"><img src={rc.icon} alt={rc.name} width="48" height="48" /></div>
          <h3 style="font-size:1rem;margin-bottom:0.25rem;color:var(--color-text);">{rc.name}</h3>
          <p>{rc.description}</p>
        </a>
      ))}
    </div>
  </div>

  <KofiButton />
  <FeedbackWidget calculatorName={calc.name} />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Tile Calculator",
      "url": "https://tradecalchub.com/calculators/tile",
      "description": description,
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradecalchub.com" },
        { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://tradecalchub.com/calculators" },
        { "@type": "ListItem", "position": 3, "name": calc.shortName }
      ]
    })} />
  </Fragment>
</BaseLayout>

<script>
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const $$ = (s: string) => document.querySelectorAll(s);
  const val = (s: string) => parseFloat(($(s) as HTMLInputElement).value) || 0;

  let unit: 'imperial' | 'metric' = 'imperial';
  let shape = 'rectangle';

  $$('#unitToggle button').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('#unitToggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      unit = (btn as HTMLElement).dataset.unit as 'imperial' | 'metric';
      $$('.unit-label').forEach(el => el.textContent = `(${unit === 'imperial' ? 'feet' : 'meters'})`);
      $('#tileLenHint').textContent = unit === 'imperial' ? '(inches)' : '(cm)';
      $('#tileWidHint').textContent = unit === 'imperial' ? '(inches)' : '(cm)';
    });
  });

  // Shape toggle
  $$('.shape-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('.shape-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      shape = (btn as HTMLElement).dataset.shape!;
      $('#rectInputs').style.display = shape === 'rectangle' ? '' : 'none';
      $('#lInputs').style.display = shape === 'l-shape' ? '' : 'none';
      $('#uInputs').style.display = shape === 'u-shape' ? '' : 'none';
      $('#triInputs').style.display = shape === 'triangle' ? '' : 'none';
    });
  });

  $('#calcBtn').addEventListener('click', () => {
    const m2ft = 3.28084;
    let roomSqFt = 0;

    if (shape === 'rectangle') {
      let al = val('#areaLength'), aw = val('#areaWidth');
      if (unit === 'metric') { al *= m2ft; aw *= m2ft; }
      roomSqFt = al * aw;
    } else if (shape === 'l-shape') {
      let l1l = val('#l1Length'), l1w = val('#l1Width'), l2l = val('#l2Length'), l2w = val('#l2Width');
      if (unit === 'metric') { l1l *= m2ft; l1w *= m2ft; l2l *= m2ft; l2w *= m2ft; }
      roomSqFt = (l1l * l1w) + (l2l * l2w);
    } else if (shape === 'u-shape') {
      let u1l = val('#u1Length'), u1w = val('#u1Width'), u2l = val('#u2Length'), u2w = val('#u2Width'), u3l = val('#u3Length'), u3w = val('#u3Width');
      if (unit === 'metric') { u1l *= m2ft; u1w *= m2ft; u2l *= m2ft; u2w *= m2ft; u3l *= m2ft; u3w *= m2ft; }
      roomSqFt = (u1l * u1w) + (u2l * u2w) + (u3l * u3w);
    } else {
      let b = val('#triBase'), h = val('#triHeight');
      if (unit === 'metric') { b *= m2ft; h *= m2ft; }
      roomSqFt = 0.5 * b * h;
    }

    // Subtract obstacles
    let obstacles = val('#obstacles');
    if (unit === 'metric') obstacles *= (m2ft * m2ft * 0.092903); // m² to sq ft - actually just convert: val is in m², so × 10.764
    // Actually: if metric, user enters m², we need sq ft. 1 m² = 10.764 sq ft
    if (unit === 'metric' && obstacles > 0) obstacles *= 10.764;
    roomSqFt -= obstacles;

    let tl = val('#tileLength'), tw = val('#tileWidth');
    if (unit === 'metric') { tl *= 0.393701; tw *= 0.393701; }

    const tileSqFt = (tl * tw) / 144;
    if (roomSqFt <= 0 || tileSqFt <= 0) return;

    const wastePct = parseInt((document.querySelector('#waste') as HTMLSelectElement).value) / 100;
    const areaWithWaste = roomSqFt * (1 + wastePct);
    const tilesNeeded = Math.ceil(areaWithWaste / tileSqFt);

    const areaLabel = (sqft: number) => unit === 'metric'
      ? `${(sqft * 0.092903).toFixed(1)} m²`
      : `${sqft.toFixed(1)} sq ft`;

    $('#resArea').textContent = areaLabel(roomSqFt);
    $('#resAreaWaste').textContent = areaLabel(areaWithWaste);
    $('#resTiles').textContent = tilesNeeded.toLocaleString();

    const tilesPerBox = val('#tilesPerBox');
    if (tilesPerBox > 0) {
      const boxes = Math.ceil(tilesNeeded / tilesPerBox);
      $('#resBoxes').textContent = `${boxes} box${boxes > 1 ? 'es' : ''}`;
      $('#boxRow').style.display = '';
    } else {
      $('#boxRow').style.display = 'none';
    }

    // Grout calculation
    const groutWidth = parseFloat((document.querySelector('#groutWidth') as HTMLSelectElement).value);
    if (groutWidth > 0) {
      // Tile perimeter in inches
      const tilePerimeter = 2 * (tl + tw);
      // lbs = tiles × tilePerimeter × groutWidth × groutDepth(0.375") / 13.5
      const groutLbs = Math.ceil(tilesNeeded * tilePerimeter * groutWidth * 0.375 / 13.5);
      const groutBags = Math.ceil(groutLbs / 25); // 25 lb bags
      $('#resGrout').textContent = `${groutLbs} lbs (~${groutBags} bag${groutBags > 1 ? 's' : ''} of 25 lb)`;
      $('#groutRow').style.display = '';
    } else {
      $('#groutRow').style.display = 'none';
    }

    // Thinset calculation
    const addThinset = (document.querySelector('#thinset') as HTMLSelectElement).value === 'yes';
    if (addThinset) {
      const thinsetBags = Math.ceil(areaWithWaste / 65);
      $('#resThinset').textContent = `${thinsetBags} bag${thinsetBags > 1 ? 's' : ''}`;
      $('#thinsetRow').style.display = '';
    } else {
      $('#thinsetRow').style.display = 'none';
    }

    const cost = val('#costPerSqFt');
    if (cost > 0) {
      $('#resCost').textContent = `$${(areaWithWaste * cost).toFixed(2)}`;
      $('#costRow').style.display = '';
    } else {
      $('#costRow').style.display = 'none';
    }

    $('#results').classList.add('visible');
  });


</script>
