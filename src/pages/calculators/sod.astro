---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculators } from '../../data/calculators';
import FeedbackWidget from '../../components/FeedbackWidget.astro';
import KofiButton from '../../components/KofiButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getAffiliateLinksForCalculator } from '../../data/affiliates';
const calc = calculators.find(c => c.slug === 'sod')!;
const relatedCalcs = calc.related.map(r => calculators.find(c => c.slug === r)!);
const affiliateLinks = getAffiliateLinksForCalculator('sod');
const title = 'Sod & Grass Seed Calculator | Coverage by Area';
const description = 'Free sod and grass seed calculator. Estimate rolls of sod or pounds of seed for new lawns and overseeding. Imperial & metric support.';
---

<BaseLayout title={title} description={description} canonical="/calculators/sod">
  <nav class="breadcrumbs">
    <a href="/">Home</a><span>/</span><a href="/calculators">Calculators</a><span>/</span>Sod
  </nav>

  <div class="calc-card">
    <h1>Sod & Grass Seed Calculator</h1>
    <p class="subtitle">Calculate sod rolls or grass seed needed for your lawn area.</p>

    <div class="unit-toggle" id="unitToggle">
      <button class="active" data-unit="imperial">Imperial (ft)</button>
      <button data-unit="metric">Metric (m)</button>
    </div>

    <div>
      <label style="font-weight:600;font-size:0.875rem;margin-bottom:0.5rem;display:block;">Coverage Type</label>
      <div class="shape-selector">
        <button class="shape-btn type-btn active" data-type="sod">Sod</button>
        <button class="shape-btn type-btn" data-type="seed">Grass Seed</button>
      </div>
    </div>

    <!-- Lawn Shape Selector -->
    <div>
      <label style="font-weight:600;font-size:0.875rem;margin-bottom:0.5rem;display:block;">Lawn Shape</label>
      <div class="shape-selector">
        <button class="shape-btn lawn-shape active" data-shape="rectangle">Rectangle</button>
        <button class="shape-btn lawn-shape" data-shape="l-shape">L-Shape</button>
        <button class="shape-btn lawn-shape" data-shape="circle">Circle</button>
        <button class="shape-btn lawn-shape" data-shape="oval">Oval</button>
        <button class="shape-btn lawn-shape" data-shape="triangle">Triangle</button>
      </div>
    </div>

    <!-- Rectangle Inputs (default) -->
    <div id="rectInputs">
      <div class="form-row">
        <div class="form-group">
          <label>Lawn Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Lawn Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="width" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- L-Shape Inputs -->
    <div id="lInputs" style="display:none;">
      <div class="form-row">
        <div class="form-group">
          <label>Section 1 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l1Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 1 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l1Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Section 2 Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l2Length" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Section 2 Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="l2Width" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- Circle Inputs -->
    <div id="circleInputs" style="display:none;">
      <div class="form-group">
        <label>Radius <span class="hint unit-label">(feet)</span></label>
        <input type="number" id="circleRadius" placeholder="0" min="0" step="any" />
      </div>
    </div>

    <!-- Oval Inputs -->
    <div id="ovalInputs" style="display:none;">
      <div class="form-row">
        <div class="form-group">
          <label>Oval Length <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="ovalLength" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Oval Width <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="ovalWidth" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- Triangle Inputs -->
    <div id="triInputs" style="display:none;">
      <div class="form-row">
        <div class="form-group">
          <label>Base <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="triBase" placeholder="0" min="0" step="any" />
        </div>
        <div class="form-group">
          <label>Height <span class="hint unit-label">(feet)</span></label>
          <input type="number" id="triHeight" placeholder="0" min="0" step="any" />
        </div>
      </div>
    </div>

    <div id="seedOptions" style="display:none;">
      <div class="form-group">
        <label>Application</label>
        <select id="seedApp">
          <option value="new">New lawn (higher seeding rate)</option>
          <option value="overseed">Overseeding existing lawn</option>
        </select>
      </div>
      <div class="form-group">
        <label>Grass Type</label>
        <select id="grassType">
          <option value="kentucky-bluegrass">Kentucky Bluegrass (2-3 lbs/1000 sq ft)</option>
          <option value="tall-fescue">Tall Fescue (6-8 lbs/1000 sq ft)</option>
          <option value="bermuda">Bermuda Grass (1-2 lbs/1000 sq ft)</option>
          <option value="perennial-rye">Perennial Ryegrass (6-8 lbs/1000 sq ft)</option>
          <option value="zoysia">Zoysia (1-2 lbs/1000 sq ft)</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Cost per Unit <span class="hint" id="costHint">(optional, $ per roll)</span></label>
      <input type="number" id="cost" placeholder="0" min="0" step="any" />
    </div>

    <!-- Advanced Options -->
    <details class="advanced-options">
      <summary>Advanced Options</summary>
      <div class="advanced-inner">
        <div class="form-group">
          <label>Subtract Areas <span class="hint">(total sq ft for gardens, paths, trees)</span></label>
          <input type="number" id="subtractArea" placeholder="0" min="0" step="any" value="0" />
        </div>
      </div>
    </details>

    <button class="btn-calculate" id="calcBtn">Calculate</button>

    <div class="results-panel" id="results">
      <h2>Results</h2>
      <div class="result-row">
        <span class="result-label">Lawn Area</span>
        <span class="result-value" id="resArea">—</span>
      </div>
      <div class="result-row">
        <span class="result-label" id="quantityLabel">Sod Rolls</span>
        <span class="result-value" id="resQuantity">—</span>
      </div>
      <div class="result-row" id="palletRow">
        <span class="result-label">Pallets (approx)</span>
        <span class="result-value" id="resPallets">—</span>
      </div>
      <div class="result-row" id="costRow" style="display:none;">
        <span class="result-label">Estimated Cost</span>
        <span class="result-value" id="resCost">—</span>
      </div>
      <p class="result-note">Order 5% extra sod for trimming waste. Sod roll sizes vary by supplier. Most common is 2' × 5' (10 sq ft).</p>
      <ShareButtons />
    </div>
  </div>

  <div class="ad-slot">Advertisement</div>

  <div class="content-section">
    <h2>How to Calculate Sod</h2>
    <p>Sod is sold in rolls or pieces, typically covering 10 sq ft each (2' × 5'). To calculate how much you need, measure your lawn area and divide by the roll size.</p>

    <h3>Sod Formula</h3>
    <div class="formula-box">
      Lawn Area = Length × Width (in sq ft)<br>
      Circle: π × radius²<br>
      Oval: π × (length/2) × (width/2)<br>
      Triangle: 0.5 × base × height<br>
      Rolls = Area × 1.05 (5% waste) / 10 sq ft per roll<br>
      Pallets = Rolls / 50 (most pallets hold ~450-500 sq ft)
    </div>

    <h3>Grass Seed Rates</h3>
    <p>Seeding rates vary by grass type and whether you're establishing a new lawn or overseeding:</p>
    <ul>
      <li><strong>Kentucky Bluegrass:</strong> 2-3 lbs/1,000 sq ft (new), 1-2 lbs (overseed)</li>
      <li><strong>Tall Fescue:</strong> 6-8 lbs/1,000 sq ft (new), 3-4 lbs (overseed)</li>
      <li><strong>Bermuda Grass:</strong> 1-2 lbs/1,000 sq ft (new), 0.5-1 lb (overseed)</li>
      <li><strong>Perennial Ryegrass:</strong> 6-8 lbs/1,000 sq ft (new), 3-4 lbs (overseed)</li>
      <li><strong>Zoysia:</strong> 1-2 lbs/1,000 sq ft (new), 0.5-1 lb (overseed)</li>
    </ul>

    <h3>Sod vs. Seed</h3>
    <ul>
      <li><strong>Sod:</strong> Instant lawn, prevents erosion immediately. $0.30-0.80 per sq ft installed.</li>
      <li><strong>Seed:</strong> Cheaper ($0.05-0.15 per sq ft), but takes 2-3 weeks to germinate and 6-8 weeks for full coverage.</li>
      <li>Sod is best for slopes, high-traffic areas, and when you need immediate results.</li>
      <li>Seed is best for large areas, budget projects, and when you can wait for results.</li>
    </ul>

    <h3>Installation Tips</h3>
    <ul>
      <li>Install sod within 24 hours of delivery. It starts dying quickly in summer heat</li>
      <li>Prepare soil first: grade, rake, and add topsoil/compost as needed</li>
      <li>Stagger sod seams like bricks. Don't line them up</li>
      <li>Water heavily for the first 2 weeks (1" per day) to establish roots</li>
    </ul>
    <p>After laying sod, use a <a href={affiliateLinks[0]?.url} target="_blank">{affiliateLinks[0]?.text}</a> to press rolls firmly into the soil for better root contact. Consider laying <a href={affiliateLinks[1]?.url} target="_blank">{affiliateLinks[1]?.text}</a> around garden beds to suppress weeds near the new lawn.</p>
  </div>

  <div class="related-calcs" style="margin-top:2rem;">
    <h2 style="font-size:1.25rem;margin-bottom:1rem;">Related Calculators</h2>
    <div class="calc-grid" style="max-width:100%;">
      {relatedCalcs.map(rc => (
        <a href={`/calculators/${rc.slug}`} class="calc-grid-item">
          <div class="icon"><img src={rc.icon} alt={rc.name} width="48" height="48" /></div>
          <h3 style="font-size:1rem;margin-bottom:0.25rem;color:var(--color-text);">{rc.name}</h3>
          <p>{rc.description}</p>
        </a>
      ))}
    </div>
  </div>

  <KofiButton />
  <FeedbackWidget calculatorName={calc.name} />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Sod & Grass Seed Calculator",
      "url": "https://tradecalchub.com/calculators/sod",
      "description": description,
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradecalchub.com" },
        { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://tradecalchub.com/calculators" },
        { "@type": "ListItem", "position": 3, "name": calc.shortName }
      ]
    })} />
  </Fragment>
</BaseLayout>

<script>
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const $$ = (s: string) => document.querySelectorAll(s);
  const val = (s: string) => parseFloat(($(s) as HTMLInputElement).value) || 0;

  let unit: 'imperial' | 'metric' = 'imperial';
  let coverType: 'sod' | 'seed' = 'sod';
  let lawnShape = 'rectangle';

  const seedRates: Record<string, { newRate: number; overseedRate: number }> = {
    'kentucky-bluegrass': { newRate: 2.5, overseedRate: 1.5 },
    'tall-fescue': { newRate: 7, overseedRate: 3.5 },
    'bermuda': { newRate: 1.5, overseedRate: 0.75 },
    'perennial-rye': { newRate: 7, overseedRate: 3.5 },
    'zoysia': { newRate: 1.5, overseedRate: 0.75 },
  };

  $$('#unitToggle button').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('#unitToggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      unit = (btn as HTMLElement).dataset.unit as 'imperial' | 'metric';
      $$('.unit-label').forEach(el => el.textContent = `(${unit === 'imperial' ? 'feet' : 'meters'})`);
    });
  });

  // Type toggle (sod/seed)
  $$('.type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('.type-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      coverType = (btn as HTMLElement).dataset.type as 'sod' | 'seed';
      $('#seedOptions').style.display = coverType === 'seed' ? '' : 'none';
      $('#costHint').textContent = coverType === 'sod' ? '(optional, $ per roll)' : '(optional, $ per lb)';
    });
  });

  // Lawn shape toggle
  $$('.lawn-shape').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('.lawn-shape').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      lawnShape = (btn as HTMLElement).dataset.shape!;
      $('#rectInputs').style.display = lawnShape === 'rectangle' ? '' : 'none';
      $('#lInputs').style.display = lawnShape === 'l-shape' ? '' : 'none';
      $('#circleInputs').style.display = lawnShape === 'circle' ? '' : 'none';
      $('#ovalInputs').style.display = lawnShape === 'oval' ? '' : 'none';
      $('#triInputs').style.display = lawnShape === 'triangle' ? '' : 'none';
    });
  });

  $('#calcBtn').addEventListener('click', () => {
    const m2ft = 3.28084;
    let sqFt = 0;

    if (lawnShape === 'rectangle') {
      let l = val('#length'), w = val('#width');
      if (unit === 'metric') { l *= m2ft; w *= m2ft; }
      sqFt = l * w;
    } else if (lawnShape === 'l-shape') {
      let l1l = val('#l1Length'), l1w = val('#l1Width'), l2l = val('#l2Length'), l2w = val('#l2Width');
      if (unit === 'metric') { l1l *= m2ft; l1w *= m2ft; l2l *= m2ft; l2w *= m2ft; }
      sqFt = (l1l * l1w) + (l2l * l2w);
    } else if (lawnShape === 'circle') {
      let r = val('#circleRadius');
      if (unit === 'metric') r *= m2ft;
      sqFt = Math.PI * r * r;
    } else if (lawnShape === 'oval') {
      let ol = val('#ovalLength'), ow = val('#ovalWidth');
      if (unit === 'metric') { ol *= m2ft; ow *= m2ft; }
      sqFt = Math.PI * (ol / 2) * (ow / 2);
    } else {
      let b = val('#triBase'), h = val('#triHeight');
      if (unit === 'metric') { b *= m2ft; h *= m2ft; }
      sqFt = 0.5 * b * h;
    }

    // Subtract areas
    let subtract = val('#subtractArea');
    if (unit === 'metric' && subtract > 0) subtract *= 10.764; // m² to sq ft
    sqFt -= subtract;

    if (sqFt <= 0) return;

    const areaLabel = unit === 'metric'
      ? `${(sqFt * 0.092903).toFixed(0)} m²`
      : `${sqFt.toFixed(0)} sq ft`;
    $('#resArea').textContent = areaLabel;

    if (coverType === 'sod') {
      const rolls = Math.ceil(sqFt * 1.05 / 10);
      const pallets = Math.ceil(rolls / 50);
      $('#quantityLabel').textContent = 'Sod Rolls (2\'×5\')';
      $('#resQuantity').textContent = `${rolls.toLocaleString()} rolls`;
      $('#resPallets').textContent = `${pallets} pallet${pallets > 1 ? 's' : ''}`;
      $('#palletRow').style.display = '';

      const cost = val('#cost');
      if (cost > 0) {
        $('#resCost').textContent = `$${(rolls * cost).toFixed(2)}`;
        $('#costRow').style.display = '';
      } else {
        $('#costRow').style.display = 'none';
      }
    } else {
      const grassType = (document.querySelector('#grassType') as HTMLSelectElement).value;
      const isNew = (document.querySelector('#seedApp') as HTMLSelectElement).value === 'new';
      const rate = isNew ? seedRates[grassType].newRate : seedRates[grassType].overseedRate;
      const lbs = Math.ceil((sqFt / 1000) * rate);

      $('#quantityLabel').textContent = 'Grass Seed';
      $('#resQuantity').textContent = `${lbs} lbs`;
      $('#palletRow').style.display = 'none';

      const cost = val('#cost');
      if (cost > 0) {
        $('#resCost').textContent = `$${(lbs * cost).toFixed(2)}`;
        $('#costRow').style.display = '';
      } else {
        $('#costRow').style.display = 'none';
      }
    }

    $('#results').classList.add('visible');
  });


</script>
