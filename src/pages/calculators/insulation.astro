---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculators } from '../../data/calculators';
import FeedbackWidget from '../../components/FeedbackWidget.astro';
import KofiButton from '../../components/KofiButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getAffiliateLinksForCalculator } from '../../data/affiliates';
const calc = calculators.find(c => c.slug === 'insulation')!;
const relatedCalcs = calc.related.map(r => calculators.find(c => c.slug === r)!);
const affiliateLinks = getAffiliateLinksForCalculator('insulation');
const title = 'Insulation Calculator | Batts, Rolls & Blown-In';
const description = 'Free insulation calculator. Estimate batts, rolls, or blown-in insulation for walls, attics, and crawl spaces. Includes R-value guidance.';
---

<BaseLayout title={title} description={description} canonical="/calculators/insulation">
  <nav class="breadcrumbs">
    <a href="/">Home</a><span>/</span><a href="/calculators">Calculators</a><span>/</span>Insulation
  </nav>

  <div class="calc-card">
    <h1>Insulation Calculator</h1>
    <p class="subtitle">Calculate batts, rolls, or bags of blown-in insulation for your project.</p>

    <div class="unit-toggle" id="unitToggle">
      <button class="active" data-unit="imperial">Imperial (ft)</button>
      <button data-unit="metric">Metric (m)</button>
    </div>

    <div class="form-group">
      <label>Application</label>
      <select id="application">
        <option value="wall">Walls (stud cavities)</option>
        <option value="attic">Attic (between joists / blown-in)</option>
        <option value="floor">Floor / Crawl Space</option>
      </select>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Total Length <span class="hint unit-label">(feet)</span></label>
        <input type="number" id="length" placeholder="0" min="0" step="any" />
      </div>
      <div class="form-group">
        <label>Height / Width <span class="hint unit-label">(feet)</span></label>
        <input type="number" id="height" placeholder="0" min="0" step="any" />
      </div>
    </div>

    <div class="form-group">
      <label>Insulation Type</label>
      <select id="insulationType">
        <option value="batt-r13">Fiberglass Batt R-13 (3.5", 2×4 walls)</option>
        <option value="batt-r19">Fiberglass Batt R-19 (6.25", 2×6 walls)</option>
        <option value="batt-r30">Fiberglass Batt R-30 (9.5", attic)</option>
        <option value="batt-r38">Fiberglass Batt R-38 (12", attic)</option>
        <option value="blown-cellulose">Blown-In Cellulose (attic)</option>
        <option value="blown-fiberglass">Blown-In Fiberglass (attic)</option>
        <option value="rigid-r5">Rigid Foam R-5 (1" board)</option>
        <option value="rigid-r10">Rigid Foam R-10 (2" board)</option>
      </select>
    </div>

    <div class="form-group">
      <label>Stud Spacing (for batts)</label>
      <select id="studSpacing">
        <option value="16" selected>16" on center (standard)</option>
        <option value="24">24" on center</option>
      </select>
    </div>

    <!-- Advanced Options -->
    <details class="advanced-options" id="advancedOptions">
      <summary>Advanced Options</summary>
      <div class="advanced-inner">

        <div id="wallOpenings">
          <span class="advanced-section-label">Doors to Subtract</span>
          <div class="opening-rows" id="doorRows">
            <div class="opening-row" data-row="door">
              <select class="door-type">
                <option value="21">Interior (21 sq ft)</option>
                <option value="23">Exterior (23 sq ft)</option>
                <option value="40">Sliding Glass (40 sq ft)</option>
                <option value="custom">Custom (H × W)</option>
              </select>
              <div class="custom-dims" style="display:none;">
                <input type="number" class="door-h" placeholder="H" min="0" step="any" />
                <input type="number" class="door-w" placeholder="W" min="0" step="any" />
              </div>
              <input type="number" class="qty-input" value="0" min="0" step="1" title="Count" />
              <button type="button" class="btn-remove-row" title="Remove">×</button>
            </div>
          </div>
          <button type="button" class="btn-add-row" id="addDoorRow">+ Add door type</button>

          <span class="advanced-section-label" style="margin-top:0.75rem;">Windows to Subtract</span>
          <div class="opening-rows" id="windowRows">
            <div class="opening-row" data-row="window">
              <select class="window-type">
                <option value="12">Standard (12 sq ft)</option>
                <option value="6">Small (6 sq ft)</option>
                <option value="20">Picture (20 sq ft)</option>
                <option value="30">Bay (30 sq ft)</option>
                <option value="custom">Custom (H × W)</option>
              </select>
              <div class="custom-dims" style="display:none;">
                <input type="number" class="win-h" placeholder="H" min="0" step="any" />
                <input type="number" class="win-w" placeholder="W" min="0" step="any" />
              </div>
              <input type="number" class="qty-input" value="0" min="0" step="1" title="Count" />
              <button type="button" class="btn-remove-row" title="Remove">×</button>
            </div>
          </div>
          <button type="button" class="btn-add-row" id="addWindowRow">+ Add window type</button>
        </div>

        <div class="form-group" style="margin-top:0.75rem;">
          <label>Existing Insulation Depth <span class="hint">(inches, 0 = none)</span></label>
          <input type="number" id="existingDepth" placeholder="0" min="0" step="any" value="0" />
          <p class="hint" style="margin-top:0.25rem;font-size:0.8rem;color:var(--color-text-light);" id="existingNote"></p>
        </div>

      </div>
    </details>

    <button class="btn-calculate" id="calcBtn">Calculate Insulation</button>

    <div class="results-panel" id="results">
      <h2>Results</h2>
      <div class="result-row">
        <span class="result-label">Total Area</span>
        <span class="result-value" id="resArea">—</span>
      </div>
      <div class="result-row">
        <span class="result-label" id="qtyLabel">Quantity</span>
        <span class="result-value" id="resQty">—</span>
      </div>
      <div class="result-row">
        <span class="result-label">R-Value</span>
        <span class="result-value" id="resRvalue">—</span>
      </div>
      <div class="result-row" id="existingRow" style="display:none;">
        <span class="result-label">Existing R-Value (approx)</span>
        <span class="result-value" id="resExisting">—</span>
      </div>
      <div class="result-row" id="totalRRow" style="display:none;">
        <span class="result-label">Total R-Value After</span>
        <span class="result-value" id="resTotalR">—</span>
      </div>
      <p class="result-note">Estimates include 5% waste. Check local building codes for minimum R-value requirements.</p>
      <ShareButtons />
    </div>
  </div>

  <div class="ad-slot">Advertisement</div>

  <div class="content-section">
    <h2>How to Calculate Insulation</h2>
    <p>Insulation is measured by R-value (thermal resistance). Higher R-values mean better insulation. The amount you need depends on the area, insulation type, and your climate zone.</p>

    <h3>Insulation Formula</h3>
    <div class="formula-box">
      Total Area = Length × Height (in sq ft)<br>
      For batts: Bags = Area / Coverage per bag (check packaging)<br>
      For blown-in: Bags = Area × Depth / Coverage per bag
    </div>

    <h3>Recommended R-Values by Climate Zone</h3>
    <ul>
      <li><strong>Zone 1-2 (Hot):</strong> Walls R-13, Attic R-30 to R-49</li>
      <li><strong>Zone 3 (Warm):</strong> Walls R-13 to R-15, Attic R-30 to R-60</li>
      <li><strong>Zone 4 (Mixed):</strong> Walls R-13 to R-21, Attic R-38 to R-60</li>
      <li><strong>Zone 5-6 (Cold):</strong> Walls R-20 to R-21, Attic R-49 to R-60</li>
      <li><strong>Zone 7-8 (Very Cold):</strong> Walls R-21+, Attic R-49 to R-60</li>
    </ul>

    <h3>Insulation Types Compared</h3>
    <ul>
      <li><strong>Fiberglass batts:</strong> Most common, affordable, DIY-friendly. R-3.1 to R-3.4 per inch.</li>
      <li><strong>Blown-in cellulose:</strong> Good for attics and retrofits. R-3.2 to R-3.8 per inch. Requires blower machine.</li>
      <li><strong>Blown-in fiberglass:</strong> Lighter than cellulose, won't absorb moisture. R-2.2 to R-2.7 per inch.</li>
      <li><strong>Rigid foam (XPS/EPS):</strong> Great for basements, exterior walls. R-5 per inch (XPS).</li>
      <li><strong>Spray foam:</strong> Best R-value per inch (R-6 to R-7 closed-cell), but most expensive. Professional install required.</li>
    </ul>

    <h3>Installation Tips</h3>
    <ul>
      <li>Don't compress fiberglass batts. Compression reduces R-value</li>
      <li>Use unfaced insulation when adding to existing insulation</li>
      <li>Vapor barrier goes on the warm side (toward heated space)</li>
      <li>Wear protective equipment: long sleeves, gloves, mask, and safety glasses</li>
      <li>Don't cover soffit vents. Attics need ventilation to prevent moisture problems</li>
    </ul>
    <p>An <a href={affiliateLinks[0]?.url} target="_blank">{affiliateLinks[0]?.text}</a> speeds up batt installation in stud cavities. Browse <a href={affiliateLinks[1]?.url} rel="nofollow sponsored" target="_blank">{affiliateLinks[1]?.text}</a> to compare R-values and pricing for your project.</p>
  </div>

  <div class="related-calcs" style="margin-top:2rem;">
    <h2 style="font-size:1.25rem;margin-bottom:1rem;">Related Calculators</h2>
    <div class="calc-grid" style="max-width:100%;">
      {relatedCalcs.map(rc => (
        <a href={`/calculators/${rc.slug}`} class="calc-grid-item">
          <div class="icon"><img src={rc.icon} alt={rc.name} width="48" height="48" /></div>
          <h3 style="font-size:1rem;margin-bottom:0.25rem;color:var(--color-text);">{rc.name}</h3>
          <p>{rc.description}</p>
        </a>
      ))}
    </div>
  </div>

  <KofiButton />
  <FeedbackWidget calculatorName={calc.name} />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Insulation Calculator",
      "url": "https://tradecalchub.com/calculators/insulation",
      "description": description,
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradecalchub.com" },
        { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://tradecalchub.com/calculators" },
        { "@type": "ListItem", "position": 3, "name": calc.shortName }
      ]
    })} />
  </Fragment>
</BaseLayout>

<script>
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const $$ = (s: string) => document.querySelectorAll(s);
  const val = (s: string) => parseFloat(($(s) as HTMLInputElement).value) || 0;

  let unit: 'imperial' | 'metric' = 'imperial';

  interface InsulationData {
    rValue: string;
    rNumeric: number;
    coveragePerBag: number;
    unitLabel: string;
    isBlown: boolean;
    rPerInch: number;
  }

  const insulationData: Record<string, InsulationData> = {
    'batt-r13': { rValue: 'R-13', rNumeric: 13, coveragePerBag: 40, unitLabel: 'bags (batts)', isBlown: false, rPerInch: 3.7 },
    'batt-r19': { rValue: 'R-19', rNumeric: 19, coveragePerBag: 48.96, unitLabel: 'bags (batts)', isBlown: false, rPerInch: 3.0 },
    'batt-r30': { rValue: 'R-30', rNumeric: 30, coveragePerBag: 31.25, unitLabel: 'bags (batts)', isBlown: false, rPerInch: 3.2 },
    'batt-r38': { rValue: 'R-38', rNumeric: 38, coveragePerBag: 24, unitLabel: 'bags (batts)', isBlown: false, rPerInch: 3.2 },
    'blown-cellulose': { rValue: 'R-38 (at 10.5")', rNumeric: 38, coveragePerBag: 40, unitLabel: 'bags (30 lb)', isBlown: true, rPerInch: 3.5 },
    'blown-fiberglass': { rValue: 'R-30 (at 10.5")', rNumeric: 30, coveragePerBag: 27, unitLabel: 'bags (25 lb)', isBlown: true, rPerInch: 2.5 },
    'rigid-r5': { rValue: 'R-5', rNumeric: 5, coveragePerBag: 32, unitLabel: 'sheets (4×8)', isBlown: false, rPerInch: 5.0 },
    'rigid-r10': { rValue: 'R-10', rNumeric: 10, coveragePerBag: 32, unitLabel: 'sheets (4×8)', isBlown: false, rPerInch: 5.0 },
  };

  $$('#unitToggle button').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('#unitToggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      unit = (btn as HTMLElement).dataset.unit as 'imperial' | 'metric';
      $$('.unit-label').forEach(el => el.textContent = `(${unit === 'imperial' ? 'feet' : 'meters'})`);
    });
  });

  // Show/hide wall openings based on application
  const appSelect = document.querySelector('#application') as HTMLSelectElement;
  appSelect.addEventListener('change', () => {
    $('#wallOpenings').style.display = appSelect.value === 'wall' ? '' : 'none';
  });

  // --- Dynamic row helpers ---
  function setupCustomToggle(row: Element, typeClass: string, dimsSelector: string) {
    const select = row.querySelector(typeClass) as HTMLSelectElement;
    const dims = row.querySelector(dimsSelector) as HTMLElement;
    if (!select || !dims) return;
    select.addEventListener('change', () => {
      dims.style.display = select.value === 'custom' ? '' : 'none';
    });
  }

  function addDoorRow() {
    const container = $('#doorRows');
    const row = document.createElement('div');
    row.className = 'opening-row';
    row.dataset.row = 'door';
    row.innerHTML = `
      <select class="door-type">
        <option value="21">Interior (21 sq ft)</option>
        <option value="23">Exterior (23 sq ft)</option>
        <option value="40">Sliding Glass (40 sq ft)</option>
        <option value="custom">Custom (H × W)</option>
      </select>
      <div class="custom-dims" style="display:none;">
        <input type="number" class="door-h" placeholder="H" min="0" step="any" />
        <input type="number" class="door-w" placeholder="W" min="0" step="any" />
      </div>
      <input type="number" class="qty-input" value="1" min="0" step="1" title="Count" />
      <button type="button" class="btn-remove-row" title="Remove">×</button>`;
    container.appendChild(row);
    setupCustomToggle(row, '.door-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  }

  function addWindowRow() {
    const container = $('#windowRows');
    const row = document.createElement('div');
    row.className = 'opening-row';
    row.dataset.row = 'window';
    row.innerHTML = `
      <select class="window-type">
        <option value="12">Standard (12 sq ft)</option>
        <option value="6">Small (6 sq ft)</option>
        <option value="20">Picture (20 sq ft)</option>
        <option value="30">Bay (30 sq ft)</option>
        <option value="custom">Custom (H × W)</option>
      </select>
      <div class="custom-dims" style="display:none;">
        <input type="number" class="win-h" placeholder="H" min="0" step="any" />
        <input type="number" class="win-w" placeholder="W" min="0" step="any" />
      </div>
      <input type="number" class="qty-input" value="1" min="0" step="1" title="Count" />
      <button type="button" class="btn-remove-row" title="Remove">×</button>`;
    container.appendChild(row);
    setupCustomToggle(row, '.window-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  }

  // Wire up initial rows
  document.querySelectorAll('#doorRows .opening-row').forEach(row => {
    setupCustomToggle(row, '.door-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  });
  document.querySelectorAll('#windowRows .opening-row').forEach(row => {
    setupCustomToggle(row, '.window-type', '.custom-dims');
    row.querySelector('.btn-remove-row')!.addEventListener('click', () => row.remove());
  });

  $('#addDoorRow').addEventListener('click', addDoorRow);
  $('#addWindowRow').addEventListener('click', addWindowRow);

  // --- Area helper ---
  function getOpeningArea(containerSelector: string, typeClass: string, hClass: string, wClass: string): number {
    let total = 0;
    document.querySelectorAll(`${containerSelector} .opening-row`).forEach(row => {
      const select = row.querySelector(typeClass) as HTMLSelectElement;
      const qty = parseFloat((row.querySelector('.qty-input') as HTMLInputElement).value) || 0;
      if (select.value === 'custom') {
        let h = parseFloat((row.querySelector(hClass) as HTMLInputElement).value) || 0;
        let w = parseFloat((row.querySelector(wClass) as HTMLInputElement).value) || 0;
        if (unit === 'metric') { h *= 3.28084; w *= 3.28084; }
        total += h * w * qty;
      } else {
        total += parseFloat(select.value) * qty;
      }
    });
    return total;
  }

  // Existing depth note
  const existingDepthInput = document.querySelector('#existingDepth') as HTMLInputElement;
  existingDepthInput.addEventListener('input', () => {
    const d = parseFloat(existingDepthInput.value) || 0;
    if (d > 0) {
      // Approximate existing R-value: ~3.2 per inch for typical fiberglass
      const approxR = (d * 3.2).toFixed(0);
      $('#existingNote').textContent = `Existing insulation is approximately R-${approxR}. New insulation adds on top.`;
    } else {
      $('#existingNote').textContent = '';
    }
  });

  // --- Main calculation ---
  $('#calcBtn').addEventListener('click', () => {
    let l = val('#length'), h = val('#height');
    if (unit === 'metric') { l *= 3.28084; h *= 3.28084; }

    let area = l * h;

    // Subtract openings for wall applications
    if (appSelect.value === 'wall') {
      const doorArea = getOpeningArea('#doorRows', '.door-type', '.door-h', '.door-w');
      const windowArea = getOpeningArea('#windowRows', '.window-type', '.win-h', '.win-w');
      area -= (doorArea + windowArea);
    }

    if (area <= 0) return;

    const type = (document.querySelector('#insulationType') as HTMLSelectElement).value;
    const data = insulationData[type];
    const wasteArea = area * 1.05;
    const qty = Math.ceil(wasteArea / data.coveragePerBag);

    const areaLabel = unit === 'metric'
      ? `${(area * 0.092903).toFixed(0)} m²`
      : `${area.toFixed(0)} sq ft`;

    $('#resArea').textContent = areaLabel;
    $('#qtyLabel').textContent = data.unitLabel.charAt(0).toUpperCase() + data.unitLabel.slice(1);
    $('#resQty').textContent = `${qty} ${data.unitLabel}`;
    $('#resRvalue').textContent = data.rValue;

    // Existing insulation depth
    const existingDepth = val('#existingDepth');
    if (existingDepth > 0) {
      const existingR = existingDepth * 3.2;
      const totalR = existingR + data.rNumeric;
      $('#resExisting').textContent = `~R-${existingR.toFixed(0)}`;
      $('#resTotalR').textContent = `~R-${totalR.toFixed(0)}`;
      $('#existingRow').style.display = '';
      $('#totalRRow').style.display = '';
    } else {
      $('#existingRow').style.display = 'none';
      $('#totalRRow').style.display = 'none';
    }

    $('#results').classList.add('visible');
  });


</script>
