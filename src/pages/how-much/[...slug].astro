---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { seoPages } from '../../data/seo-pages';
import { calculators } from '../../data/calculators';
import FeedbackWidget from '../../components/FeedbackWidget.astro';

export function getStaticPaths() {
  return seoPages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const calc = calculators.find(c => c.slug === page.calculator)!;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": page.h1,
  "description": page.metaDescription,
  "step": [
    {
      "@type": "HowToStep",
      "name": "Measure your project area",
      "text": "Measure the length, width, and depth/thickness of the area you need to cover."
    },
    {
      "@type": "HowToStep",
      "name": "Use the calculator",
      "text": page.prefilledNote
    },
    {
      "@type": "HowToStep",
      "name": "Order materials",
      "text": "Add 5-15% extra for waste and order from your local supplier."
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tradecalchub.com" },
    { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://tradecalchub.com/calculators" },
    { "@type": "ListItem", "position": 3, "name": calc.name, "item": `https://tradecalchub.com/calculators/${calc.slug}` },
    { "@type": "ListItem", "position": 4, "name": page.h1 }
  ]
};
---

<BaseLayout title={page.title} description={page.metaDescription} canonical={`/how-much/${page.slug}`}>
  <nav class="breadcrumbs">
    <a href="/">Home</a><span>/</span><a href="/calculators">Calculators</a><span>/</span><a href={`/calculators/${calc.slug}`}>{calc.shortName}</a><span>/</span>{page.h1.replace(/How Much |How Many |What |How Deep /i, '').slice(0, 30)}
  </nav>

  <div class="content-section">
    <h1>{page.h1}</h1>
    <div class="quick-answer">
      <Fragment set:html={page.answer} />
    </div>

    <div class="calculator-cta" style="margin:1.5rem 0;padding:1rem 1.25rem;background:var(--color-primary-light);border-radius:var(--radius-lg);border:1px solid var(--color-primary);">
      <p style="margin:0 0 0.5rem;font-weight:600;color:var(--color-primary);display:flex;align-items:center;gap:0.5rem;"><img src={calc.icon} alt="" width="24" height="24" /> Calculate Your Exact Amount</p>
      <p style="margin:0 0 0.75rem;font-size:0.9rem;color:var(--color-text);">{page.prefilledNote}</p>
      <a href={`/calculators/${calc.slug}`} style="display:inline-block;padding:0.6rem 1.25rem;background:var(--color-primary);color:#fff;border-radius:var(--radius);font-weight:600;text-decoration:none;font-size:0.9rem;">Open {calc.shortName} Calculator</a>
    </div>

    <h2>Tips for This Project</h2>
    <ul>
      {page.tips.map(tip => (
        <li>{tip}</li>
      ))}
    </ul>

    <div class="ad-slot">Advertisement</div>

    <h2>Use Our Free {calc.shortName} Calculator</h2>
    <p>Our <a href={`/calculators/${calc.slug}`}>{calc.name.toLowerCase()}</a> handles all the math for you. Enter your dimensions, choose your options, and get instant results with bag counts, cost estimates, and waste factors included.</p>
    <p>All calculations run in your browser. No signup, no data collection. <a href={`/calculators/${calc.slug}`}>Try it now</a>.</p>
  </div>

  <FeedbackWidget calculatorName={page.h1} />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <style is:inline>
      .quick-answer {
        font-size: 1.1rem;
        line-height: 1.7;
        margin: 1rem 0 1.5rem;
        padding: 1rem 1.25rem;
        background: var(--color-success-light);
        border-left: 4px solid var(--color-success);
        border-radius: 0 var(--radius) var(--radius) 0;
      }
      .quick-answer strong {
        color: var(--color-success);
      }
    </style>
  </Fragment>
</BaseLayout>
